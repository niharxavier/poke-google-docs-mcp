# Copy to .env for local runs:  cp .env.example .env
# On Render, set these in the dashboard instead (Environment tab).

# --- Google OAuth client (from Google Cloud Console > Credentials) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# --- Refresh token printed by `python setup_auth.py` ---
GOOGLE_REFRESH_TOKEN=your-refresh-token

# --- Shared secret Poke sends as a Bearer token. Generate one with: ---
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable auth (NOT recommended for a public deployment).
MCP_API_KEY=your-long-random-secret

# Local port (Render sets PORT automatically; you don't need this in prod).
PORT=8000
